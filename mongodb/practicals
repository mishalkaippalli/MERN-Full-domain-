  { name: "David", salary: 95000, department: "HR" },          // Duplicate 2nd highest
  { name: "Eve", salary: 80000, department: "Engineering" },
  { name: "Frank", salary: 70000, department: "Sales" }
]);
//ans
db.employees.aggregate([
  {$group: {
    _id: "$salary"
  }},{
    $sort: {_id: -1}},
    {$skip: 1},
    {$limit: 1},
    {$project: {_id: 0, salary: "$_id"}}
  ])


